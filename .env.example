# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=pfm_journeys
POSTGRES_USER=pfm_user
POSTGRES_PASSWORD=changeme

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_QUEUE_KEY=events_queue

# ─── Collector API ────────────────────────────────────────────────────────────
PORT_COLLECTOR=3001
# Comma-separated list of allowed origins (e.g. https://particleformen.com)
ALLOWED_ORIGINS=https://particleformen.com

# ─── Admin API ───────────────────────────────────────────────────────────────
PORT_ADMIN=3002
JWT_SECRET=changeme_use_a_long_random_string_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ─── Worker ──────────────────────────────────────────────────────────────────
WORKER_BATCH_SIZE=100
WORKER_INTERVAL_MS=3000
# How many days back fp_sessions is checked when deciding whether to merge a new
# direct session into a prior attributed one. Matches the standard 30-day ad
# attribution window used by Meta and Google. Set to 0 to disable merging.
FP_STITCH_WINDOW_DAYS=30
# How long the collector's Redis redirect key lives after a session merge.
# Should match the client session TTL (24h) so the old UUID stops being used
# by the client at the same time the redirect key expires.
FP_MERGE_REDIRECT_TTL_HOURS=72
